@* @pb-anchor source=d_productfeatures.srd kind=datawindow-form style=Freeform control=mud-card-form *@
@using ProductCatalog.Application.DTOs

<MudCard Class="pa-2" Elevation="1">
    <MudCardHeader>
        <MudCardHeaderContent>
            <MudText Typo="Typo.h6">d_productfeatures</MudText>
            @if (_rows.Count > 0)
            {
                <MudText Typo="Typo.caption">Record @(_currentIndex + 1) of @_rows.Count</MudText>
            }
        </MudCardHeaderContent>
    </MudCardHeader>
    <MudCardContent Style="max-height: 70vh; overflow-y: auto;">
        @if (_row is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
        <MudForm>
        <MudNumericField T="int" Label="Id" @bind-Value="_row.Id" Class="mb-2" />
        <MudNumericField T="int?" Label="Productitemid" @bind-Value="_row.Productitemid" Class="mb-2" />
        <MudTextField T="string" Label="Title" @bind-Value="_row.Title" Class="mb-2" />
        <MudTextField T="string" Label="Description" @bind-Value="_row.Description" Class="mb-2" />
        </MudForm>
        }
    </MudCardContent>
</MudCard>
