@page "/productitems"
@using MudBlazor
@using ProductCatalog.Blazor.Components.DataWindows
@* Generated by pb-convert-window (Skill 10) — WProductitems (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">Edit Products</MudText>
    <MudDivider Class="my-3" />

    @* Picture: p_imgproduct — no source file specified *@
    @* DataWindow: dw_productitems (DataObject: d_productitems) *@
    <Productitems  @ref="_dwProductitems"/>

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProductitems?.OnPrev())">Prev</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProductitems?.OnNext())">Next</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => { if (_dwProductitems is not null) await _dwProductitems.OnSave(); })">Update</MudButton>
    </MudStack>
</MudPaper>
