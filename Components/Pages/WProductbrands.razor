@page "/productbrands"
@using MudBlazor
@using ProductCatalog.Blazor.Components.DataWindows
@* Generated by pb-convert-window (Skill 10) — WProductbrands (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">Edit Product Brands</MudText>
    <MudDivider Class="my-3" />

    @* DataWindow: dw_productbrands (DataObject: d_productbrands) *@
    <Productbrands  @ref="_dwProductbrands"/>

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProductbrands?.OnPrev())">Prev</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProductbrands?.OnNext())">Next</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => { if (_dwProductbrands is not null) await _dwProductbrands.OnSave(); })">Update</MudButton>
    </MudStack>
</MudPaper>
