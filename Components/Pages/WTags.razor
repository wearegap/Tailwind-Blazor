@page "/tags"
@using MudBlazor
@using ProductCatalog.Blazor.Components.DataWindows
@* Generated by pb-convert-window (Skill 10) — WTags (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">Edit Product Tags</MudText>
    <MudDivider Class="my-3" />

    @* DataWindow: dw_tag (DataObject: d_tag) *@
    <Tag  @ref="_dwTag"/>

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwTag?.OnPrev())">Prev</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwTag?.OnNext())">Next</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => { if (_dwTag is not null) await _dwTag.OnSave(); })">Update</MudButton>
    </MudStack>
</MudPaper>
