@page "/main"
@using MudBlazor
@* Generated by pb-convert-window (Skill 10) — WMain (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">TailWind Products Catalog</MudText>
    <MudDivider Class="my-3" />

    @* Picture: p_1 *@
    @{ var _imgP1 = ImageCatalog.Resolve("TailWindLogo.JPG"); }
    @if (_imgP1 is not null) { <MudImage Src="@_imgP1" Alt="p_1" /> }

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCbProductfeatures_Clicked">Features</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCbProducttypes_Clicked">Types</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCbProductbrands_Clicked">Brands</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCbProductitems_Clicked">Products</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCbTagsWindow_Clicked">Tags</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCb1_Clicked">SQL Test</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCbSearch_Clicked">Search Product ...</MudButton>
    </MudStack>
</MudPaper>
