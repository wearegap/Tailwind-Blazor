@page "/productfeatures"
@using MudBlazor
@using ProductCatalog.Blazor.Components.DataWindows
@* Generated by pb-convert-window (Skill 10) — WProductfeatures (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">Edit Product Features</MudText>
    <MudDivider Class="my-3" />

    @* DataWindow: dw_productfeatures (DataObject: d_productfeatures) *@
    <Productfeatures  @ref="_dwProductfeatures"/>

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProductfeatures?.OnPrev())">Prev</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProductfeatures?.OnNext())">Next</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => { if (_dwProductfeatures is not null) await _dwProductfeatures.OnSave(); })">Update</MudButton>
    </MudStack>
</MudPaper>
