@page "/producttypes"
@using MudBlazor
@using ProductCatalog.Blazor.Components.DataWindows
@* Generated by pb-convert-window (Skill 10) — WProducttypes (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">Edit Product Types</MudText>
    <MudDivider Class="my-3" />

    @* DataWindow: dw_producttypes (DataObject: d_producttypes) *@
    <Producttypes  @ref="_dwProducttypes"/>

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProducttypes?.OnPrev())">Prev</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _dwProducttypes?.OnNext())">Next</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(async () => { if (_dwProducttypes is not null) await _dwProducttypes.OnSave(); })">Update</MudButton>
    </MudStack>
</MudPaper>
