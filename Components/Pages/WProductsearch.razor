@page "/productsearch"
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using ProductCatalog.Blazor.Components.DataWindows
@* Generated by pb-convert-window (Skill 10) — WProductsearch (target=blazor) *@

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h5">Product Search</MudText>
    <MudDivider Class="my-3" />

    @* DataWindow: dw_productsearch (DataObject: d_productsearch) *@
    <Productsearch  @ref="_dwProductsearch"
                   OnRowSelected="OnRowSelected"
                   OnRowDoubleClicked="OnRowDoubleClicked"/>
    @* StaticText: st_instructions *@
    <MudText>Please type a keyword to search for matching products and press the Search button</MudText>
    @* SingleLineEdit: sle_keyword *@
    <MudTextField Label="Search" @bind-Value="_sleKeyword" Immediate="true"
                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                  OnAdornmentClick="OnSearch"
                  OnKeyUp="OnSearchKeyUp" />

    <MudStack Row="true" Spacing="2" Class="mt-3" Justify="Justify.Center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnSearch">Search</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnCb1_Clicked">cb_1</MudButton>
    </MudStack>
</MudPaper>
